# Production environment variables
# Copy to .env and fill in real values before deploying.

SECRET_KEY=change-me-to-a-long-random-string
INTERNAL_SECRET=change-me-to-another-random-string
DEBUG=False
ALLOWED_HOSTS=example.com,backend

DB_NAME=maplord
DB_USER=maplord
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_GAME_DB=1

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

CSRF_TRUSTED_ORIGINS=https://example.com

# LiveKit (voice chat)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_PUBLIC_URL=wss://example.com/livekit
LIVEKIT_API_KEY=change-me-livekit-key
LIVEKIT_API_SECRET=change-me-livekit-secret

# Used by compose.prod.yml
TAG=latest
DOMAIN=example.com

# Grafana Cloud (monitoring)
GRAFANA_CLOUD_PROMETHEUS_URL=https://prometheus-prod-XX-prod.grafana.net/api/prom/push
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_USER=123456
GRAFANA_CLOUD_LOKI_USER=789012
GRAFANA_CLOUD_API_KEY=glc_xxxxxxxxxxxxx
