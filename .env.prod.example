# Production environment variables
# Copy to .env and fill in real values before deploying.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=zelqor.qwizi.ovh,backend

DB_NAME=zelqor
DB_USER=zelqor
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_GAME_DB=1

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

CSRF_TRUSTED_ORIGINS=https://zelqor.qwizi.ovh
CORS_ALLOWED_ORIGINS=https://zelqor.qwizi.ovh

# Frontend URL (device auth verification links)
FRONTEND_URL=https://zelqor.qwizi.ovh

# Internal API security (HMAC-SHA256 between gateway and Django)
INTERNAL_SECRET=change-me-to-a-strong-random-string
INTERNAL_SECRET_PREV=

# Official gamenode credentials
GAMENODE_CLIENT_ID=change-me-client-id
GAMENODE_CLIENT_SECRET=change-me-client-secret
GAMENODE_REGION=eu-west
GAMENODE_MAX_MATCHES=200

# LiveKit (voice chat)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_PUBLIC_URL=wss://zelqor.qwizi.ovh/livekit
LIVEKIT_API_KEY=change-me-livekit-key
LIVEKIT_API_SECRET=change-me-livekit-secret-at-least-32-chars

# Used by compose.prod.yml
TAG=latest
DOMAIN=zelqor.qwizi.ovh

# Push notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:admin@zelqor.pl

# Payments
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
