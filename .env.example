SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

DB_NAME=zelqor
DB_USER=zelqor
DB_PASSWORD=zelqor
DB_HOST=db
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_GAME_DB=1

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

CSRF_TRUSTED_ORIGINS=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Frontend URL (used by device auth flow to generate verification links)
FRONTEND_URL=http://localhost:3000

# Rust gateway
RUST_LOG=info,zelqor_gateway=info
GATEWAY_PORT=8080

# Internal API security (gateway <-> Django communication)
# HMAC-SHA256 signed requests; must be a strong random string in production
INTERNAL_SECRET=change-me-to-a-random-string
# Previous secret for zero-downtime rotation (leave empty if not rotating)
INTERNAL_SECRET_PREV=

# Official gamenode credentials (OAuth client_credentials for server:connect scope)
GAMENODE_CLIENT_ID=official-gamenode
GAMENODE_CLIENT_SECRET=dev-gamenode-secret

# LiveKit (voice chat)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_PUBLIC_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-zelqor-at-least-32-chars-long

# Used by compose.prod.yml
TAG=latest
DOMAIN=your-domain.com

# Push notifications (VAPID) — generate with: python scripts/generate_vapid_keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:your-email@example.com

# OAuth social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Steam
STEAM_WEB_API_KEY=
STEAM_APP_ID=480

# Payments
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
